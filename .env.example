# FlashSport — Configuration
# Copier ce fichier en .env et adapter les valeurs

# Base de donnees PostgreSQL
# Docker compose default: flashsport:flashsport_pwd@localhost
DATABASE_URL=postgresql://flashsport:flashsport_pwd@localhost/flashsport_tri

# Dossier de stockage des photos
UPLOAD_DIR=./uploads

# YOLO
YOLO_MODEL_PATH=yolov8n.pt
YOLO_CONFIDENCE=0.35
YOLO_ENABLED=true

# Qwen / Ollama (OCR local)
QWEN_MODEL=qwen2.5vl:3b
OLLAMA_URL=http://localhost:11434
QWEN_ENABLED=true

# Mode de traitement : "local" (lent, safe) ou "server" (GPU, rapide)
PROCESSING_MODE=local
AI_WORKERS=1

# OCR avance (consensus multi-crop) — mettre true pour activer
ADVANCED_OCR_ENABLED=false

# Filtrage sujet avance — mettre true pour activer
ADVANCED_SUBJECT_FILTERING_ENABLED=false
SUBJECT_MIN_QUALITY=0.25

# Seuils qualite
QUALITY_BLUR_THRESHOLD=40.0
QUALITY_BLUR_GOOD=200.0
SCORE_THRESHOLD_BON=0.55
SCORE_THRESHOLD_INCERTAIN=0.3

# Securite — CHANGER EN PRODUCTION
JWT_SECRET=flashsport-local-secret-change-in-prod

# CORS (origines autorisees, separees par des virgules)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174,http://flashsport.app,http://boutique.flashsport.app
